# Core binds to loopback unless LAN mode is explicitly configured with TLS.
VEQRI_ADDR=127.0.0.1:7342
VEQRI_DATA_DIR=.veqri-dev
VEQRI_DATABASE=.veqri-dev/veqri.db
VEQRI_LOG_LEVEL=info
# Rolling UTC retention for SQLite content and audit rows; 0 retains indefinitely.
VEQRI_RETENTION_DAYS=30
VEQRI_TRANSCRIPT_RETENTION=true

# Optional explicit token. When omitted the core creates a 0600 token file.
# VEQRI_AUTH_TOKEN=
# Set only for headless/test environments without an OS credential service.
# VEQRI_KEYCHAIN_DISABLED=false

# Required together for a non-loopback bind.
# VEQRI_TLS_CERT_FILE=
# VEQRI_TLS_KEY_FILE=

# Connector credentials are optional and are referenced, not persisted in SQLite.
# VEQRI_SLACK_SIGNING_SECRET_REF=keychain:veqri/slack/signing-secret
# VEQRI_SLACK_BOT_TOKEN_REF=keychain:veqri/slack/bot-token
# Direct values below are development-only fallbacks. Prefer keychain refs.
# VEQRI_SLACK_SIGNING_SECRET=
# VEQRI_MATTERMOST_TOKEN_REF=keychain:veqri/mattermost/token
# VEQRI_MATTERMOST_OUTGOING_TOKEN=
# VEQRI_TEAMS_CLIENT_SECRET_REF=keychain:veqri/teams/client-secret
VEQRI_GENERIC_WEBHOOK_SECRET=local-development-only-change-me
# VEQRI_GENERIC_WEBHOOK_SECRET_REF=keychain:veqri/webhook/signing-secret

# Optional production agent adapters. IDs become selectable through --agents/API.
# VEQRI_REMOTE_AGENT_ENDPOINT=https://agent.example/v1/run
# VEQRI_REMOTE_AGENT_TOKEN_REF=keychain:veqri/agents/remote-token
# VEQRI_REMOTE_AGENT_ID=external.remote
# VEQRI_STDIO_AGENT_COMMAND=/absolute/path/to/agent
# VEQRI_STDIO_AGENT_ARGS_JSON=["--jsonl"]
# VEQRI_STDIO_AGENT_ID=external.stdio

# Voice defaults to deterministic local simulation until a provider is configured.
VEQRI_STT_PROVIDER=mock
VEQRI_TTS_PROVIDER=mock
VEQRI_MEDIA_TRANSPORT=simulated
